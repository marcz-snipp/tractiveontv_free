{
  "name": "tot",
  "private": true,
  "version": "2.1.0",
  "description": "TOT — Tractive On TV. Suivi GPS Tractive sur Fire TV.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:firetv": "bash scripts/dev-firetv.sh",
    "dev:firetv:direct": "pnpm --filter @tot/firetv start",
    "dev:firetv:rebuild": "bash scripts/dev-firetv-rebuild.sh",
    "dev:api": "pnpm --filter @tot/api dev",
    "build:api": "pnpm --filter @tot/api build",
    "lint": "pnpm -r --parallel lint",
    "typecheck": "pnpm -r --parallel typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  }
}
