# Dev defaults — chargé en mode `expo start` (dev)
# Pour AVD Android Studio :  http://10.0.2.2:3000
# Pour Fire TV stick + API locale sur le LAN : http://<IP_LAN_du_Mac>:3000
# Pour pointer directement sur Vercel prod en dev : utiliser le wrapper `pnpm dev:firetv` (option 3)
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000
EXPO_PUBLIC_MAPTILER_KEY=
EXPO_PUBLIC_PSZ_RADIUS_M=25
